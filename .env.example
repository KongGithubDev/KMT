# ============================================
# KMusic Transfer - Environment Variables
# ============================================

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your_random_secret_key_here
BASE_URL=https://kmt.kongwatcharapong.in.th

# ============================================
# Spotify OAuth Credentials
# สร้างได้ที่: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=https://kmt.kongwatcharapong.in.th/callback/spotify

# ============================================
# YouTube Music OAuth Credentials (Google)
# สร้างได้ที่: https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
YOUTUBE_REDIRECT_URI=https://kmt.kongwatcharapong.in.th/callback/youtube

# ============================================
# Apple Music Credentials (Future)
# APPLE_DEVELOPER_TOKEN=your_developer_token
# APPLE_KEY_ID=your_key_id
# APPLE_TEAM_ID=your_team_id

# ============================================
# TIDAL Credentials (Future)
# TIDAL_CLIENT_ID=your_tidal_client_id
# TIDAL_CLIENT_SECRET=your_tidal_client_secret

# ============================================
# Development (ใช้สำหรับ local testing)
# PORT=5000
# FLASK_ENV=development
